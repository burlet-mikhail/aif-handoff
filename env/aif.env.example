# ============================================================
# Application env для прод-стека aif-handoff (api/agent/mcp).
# Зашифрованная версия лежит в env/aif.env (SOPS, см. .sops.yaml).
# На сервере распаковывается scripts/sops-decrypt.sh.
# Расшифрованный файл потребляется через compose `env_file: ./env/aif.env`.
# ============================================================

# --- Runtime credentials -----------------------------------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
OPENROUTER_API_KEY=

# --- Internal ----------------------------------------------
INTERNAL_BROADCAST_TOKEN=

# --- Git author identity (для коммитов агента) ---------------
# Используется git как author/committer без необходимости в .gitconfig.
# Push идёт через gh-аккаунты (см. README), author всегда один и тот же.
GIT_AUTHOR_NAME=Mikhail Burlet
GIT_AUTHOR_EMAIL=mihail.burlet@gmail.com
GIT_COMMITTER_NAME=Mikhail Burlet
GIT_COMMITTER_EMAIL=mihail.burlet@gmail.com

# --- Telegram (опционально) --------------------------------
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_USER_ID=

# --- Прочие настройки приложения ---------------------------
# Совпадает с прод-блоком environment в compose.production.yml;
# здесь только то, что НЕ должно лежать в открытом виде.
